{
  "name": "commons-systems-monorepo",
  "version": "1.0.0",
  "description": "Monorepo for commons.systems projects",
  "private": true,
  "type": "module",
  "workspaces": [
    "fellspiral/site",
    "fellspiral/tests",
    "videobrowser/site",
    "videobrowser/tests",
    "layout/site",
    "layout/tests"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=fellspiral/site",
    "build": "npm run build --workspace=fellspiral/site",
    "test": "npm test --workspace=fellspiral/tests",
    "test:deployed": "npm run test:deployed --workspace=fellspiral/tests",
    "preview": "npm run preview --workspace=fellspiral/site",
    "dev:videobrowser": "npm run dev --workspace=videobrowser/site",
    "build:videobrowser": "npm run build --workspace=videobrowser/site",
    "test:videobrowser": "npm test --workspace=videobrowser/tests",
    "test:videobrowser:deployed": "npm run test:deployed --workspace=videobrowser/tests",
    "preview:videobrowser": "npm run preview --workspace=videobrowser/site",
    "dev:layout": "npm run dev --workspace=layout/site",
    "build:layout": "npm run build --workspace=layout/site",
    "test:layout": "npm test --workspace=layout/tests",
    "test:layout:deployed": "npm run test:deployed --workspace=layout/tests",
    "preview:layout": "npm run preview --workspace=layout/site",
    "seed:firestore": "node fellspiral/scripts/seed-firestore.js"
  },
  "keywords": ["monorepo", "fellspiral", "tabletop", "rpg", "videobrowser", "gcs", "layout", "pdf", "booklet"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "firebase-admin": "^12.0.0"
  }
}
