rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Templates collection
    match /templates/{templateId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Pages/Cards collection
    match /pages/{pageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Card pairs collection (for poker card fronts/backs)
    match /card_pairs/{pairId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Documents collection
    match /documents/{documentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Groups collection (hierarchical organization)
    match /groups/{groupId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Tags collection
    match /tags/{tagId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default: deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
